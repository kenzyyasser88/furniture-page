* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Roboto Condensed", sans-serif;
}

body {
    background: #2b1901;
    color: #fff;
}

.main {
    width: 100%;
    background: linear-gradient(to top, rgba(77, 50, 1, 0.5) 50%, rgba(43, 25, 1, 0.9) 100%),
                url(2.jpg);
    background-size: cover;
    background-position: center;
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
}

.navbar {
    width: 80%;
    margin: auto;
    padding: 30px 0;
    display: flex;
}

.icon {
    width: 200px;
    height: 70px;
}

.logo {
    color: #bda688;
    font-size: 40px;
    font-weight: bold;
}

.left-section {
    width: 50%;
    padding: 50px 80px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.nav-bar {
    margin-bottom: 30px;
}

nav ul {
    display: flex;
    list-style: none;
    gap: 30px;
}

nav ul li a {
    text-decoration: none;
    color: #a1887f;
    font-size: 16px;
    transition: color 0.3s;
}

nav ul li a:hover {
    color: #bda688;
}

.title {
    font-size: 60px;
    color: #bda688;
    margin: 20px 0;
    font-weight: bold;
}

.discription {
    color: #d6d3d1;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', Times, serif;
    font-size: 20px;
    padding-bottom: 20px;
    margin-top: 2px;
    width: 500px;
    line-height: 1.6;
}

.btn {
    display: inline-block;
    padding: 15px 22px;
    background: #471f06;
    color: white;
    text-decoration: none;
    border-radius: 2px;
    font-size: 13px;
    margin-top: 10px;
    transition: background 0.3s;
    width: fit-content;
}

.btn:hover {
    background: #5a2808;
}

.watch-link {
    display: inline-block;
    margin-left: 10px;
    margin-top: 10px;
    color: #e0c6b4;
    font-size: 16px;
    text-decoration: underline;
    transition: color 0.3s;
}

.watch-link:hover {
    color: #bda688;
}

.statistics {
    display: flex;
    gap: 40px;
    margin-top: 40px;
    padding: 30px 0;
}

.statistics div {
    color: #d6d3d1;
}

.statistics span {
    font-size: 32px;
    font-weight: bold;
    color: #bda688;
    display: block;
    margin-bottom: 5px;
}

.right-section {
    position: absolute;
    right: 80px;
    top: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.main-image {
    width: 400px;
    height: 400px;
    border-radius: 40px;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.color-picker {
    display: flex;
    gap: 15px;
    margin-top: 20px;
}

.circle {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 2px solid #bda688;
    cursor: pointer;
    transition: transform 0.3s;
}

.circle:hover {
    transform: scale(1.2);
}

.circle:nth-child(1) {
    background-color: #8B6F47;
}

.circle:nth-child(2) {
    background-color: #5C4033;
}

.circle:nth-child(3) {
    background-color: #3E2723;
}